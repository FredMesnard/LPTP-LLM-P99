/* Author: Claude */
/* Filename: p01.pr */
/* Problem: P01 - Find the last element of a list */


:- initialize.

:- tex_file(p01).
:- thm_file(p01).

:- needs_gr(p01).
:- needs_gr($(lib)/list/list).
:- needs_thm($(lib)/list/list).

% ============================================================
% Termination
% If L is a proper list, then my_last(X,L) terminates.
% ============================================================

:- lemma(my_last:termination,
all [x,l]: succeeds list(?l) => terminates my_last(?x,?l),
[induction(
  [all l: succeeds list(?l) =>
    (all x: terminates my_last(?x,?l))],
  [step([],
    [],
    terminates my_last(?x,[]) by completion,
    all x: terminates my_last(?x,[])),
   step([y,l],
    [all x: terminates my_last(?x,?l),
     succeeds list(?l)],
    terminates my_last(?x,[?y|?l]) by completion,
    all x: terminates my_last(?x,[?y|?l]))]),
 assume(succeeds list(?l),
  [all x: terminates my_last(?x,?l),
   terminates my_last(?x,?l)],
  terminates my_last(?x,?l))]
).

% ============================================================
% Type: success implies the list argument is a proper list
% ============================================================

:- lemma(my_last:types,
all [x,l]: succeeds my_last(?x,?l) => succeeds list(?l),
induction(
 [all [x,l]: succeeds my_last(?x,?l) => succeeds list(?l)],
 [step([x],
   [],
   [succeeds list([]),
    succeeds list([?x])],
   succeeds list([?x])),
  step([x,y,l],
   [succeeds list(?l),
    succeeds my_last(?x,?l)],
   [],
   succeeds list([?y|?l]))])
).


% ============================================================
% Groundness: if my_last(X,L) succeeds and L is ground,
% then X is ground.
% ============================================================

:- lemma(my_last:ground,
all [x,l]: succeeds my_last(?x,?l) & gr(?l) => gr(?x),
[induction(
  [all [x,l]: succeeds my_last(?x,?l) => gr(?l) => gr(?x)],
  [step([x],
    [],
    assume(gr([?x]),[],gr(?x)),
    gr([?x]) => gr(?x)),
   step([x,y,l],
    [gr(?l) => gr(?x),
     succeeds my_last(?x,?l)],
    assume(gr([?y|?l]),
     [],
     gr(?x)),
    gr([?y|?l]) => gr(?x))]),
 assume(succeeds my_last(?x,?l) & gr(?l),
  [gr(?l) => gr(?x),
   gr(?x)],
  gr(?x))]
).

% ============================================================
% Membership: if my_last(X,L) succeeds, then X is a member of L
% ============================================================

:- lemma(my_last:member,
all [x,l]: succeeds my_last(?x,?l) => succeeds member(?x,?l),
induction(
 [all [x,l]: succeeds my_last(?x,?l) => succeeds member(?x,?l)],
 [step([x],
   [],
   succeeds member(?x,[?x]),
   succeeds member(?x,[?x])),
  step([x,y,l],
   [succeeds member(?x,?l),
    succeeds my_last(?x,?l)],
   [],
   succeeds member(?x,[?y|?l]))])
).

% ============================================================
% Link with append: if my_last(X,L) succeeds, then there
% exists L1 such that append(L1,[X],L) succeeds.
% ============================================================

:- theorem(my_last:append,
all [x,l]: succeeds my_last(?x,?l) =>
 (ex l1: succeeds append(?l1,[?x],?l)),
induction(
 [all [x,l]: succeeds my_last(?x,?l) =>
   (ex l1: succeeds append(?l1,[?x],?l))],
 [step([x],
   [],
   [succeeds append([],[?x],[?x]),
    ex l1: succeeds append(?l1,[?x],[?x])],
   ex l1: succeeds append(?l1,[?x],[?x])),
  step([x,y,l],
   [ex l1: succeeds append(?l1,[?x],?l),
    succeeds my_last(?x,?l)],
   exist(l1,
    succeeds append(?l1,[?x],?l),
    [succeeds append([?y|?l1],[?x],[?y|?l]),
     ex l1: succeeds append(?l1,[?x],[?y|?l])],
    ex l1: succeeds append(?l1,[?x],[?y|?l])),
   ex l1: succeeds append(?l1,[?x],[?y|?l]))])
).

% ============================================================
% Converse (auxiliary): if list(L1) and append(L1,[X],L),
% then my_last(X,L).
% ============================================================

:- lemma(my_last:append:converse:aux,
all [x,l1,l]: succeeds list(?l1) & succeeds append(?l1,[?x],?l) =>
 succeeds my_last(?x,?l),
[induction(
  [all l1: succeeds list(?l1) =>
    (all [x,l]: succeeds append(?l1,[?x],?l) =>
      succeeds my_last(?x,?l))],
  [step([],
    [],
    assume(succeeds append([],[?x],?l),
     [def succeeds append([],[?x],?l) by completion,
      ?l = [?x],
      succeeds my_last(?x,[?x])],
     succeeds my_last(?x,?l)),
    all [x,l]: succeeds append([],[?x],?l) =>
      succeeds my_last(?x,?l)),
   step([z,l1],
    [all [x,l]: succeeds append(?l1,[?x],?l) =>
      succeeds my_last(?x,?l),
     succeeds list(?l1)],
    assume(succeeds append([?z|?l1],[?x],?l),
     [def succeeds append([?z|?l1],[?x],?l) by completion,
      ex l3: ?l = [?z|?l3] & succeeds append(?l1,[?x],?l3),
      exist(l3,
       ?l = [?z|?l3] & succeeds append(?l1,[?x],?l3),
       [succeeds my_last(?x,?l3),
        succeeds my_last(?x,[?z|?l3]),
        succeeds my_last(?x,?l)],
       succeeds my_last(?x,?l))],
     succeeds my_last(?x,?l)),
    all [x,l]: succeeds append([?z|?l1],[?x],?l) =>
      succeeds my_last(?x,?l))]),
 assume(succeeds list(?l1) & succeeds append(?l1,[?x],?l),
  [all [x,l]: succeeds append(?l1,[?x],?l) =>
    succeeds my_last(?x,?l),
   succeeds my_last(?x,?l)],
  succeeds my_last(?x,?l))]
).

% ============================================================
% Converse: if append(L1,[X],L) succeeds, then my_last(X,L).
% ============================================================

:- theorem(my_last:append:converse,
all [x,l1,l]: succeeds append(?l1,[?x],?l) =>
 succeeds my_last(?x,?l),
assume(succeeds append(?l1,[?x],?l),
 [succeeds list(?l1) by lemma(append:types:1),
  succeeds my_last(?x,?l) by
   lemma(my_last:append:converse:aux)],
 succeeds my_last(?x,?l))
).

:- bye(p01).
